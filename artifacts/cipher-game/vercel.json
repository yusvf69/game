{
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install --no-frozen-lockfile --ignore-scripts",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://game-api-server-zeta.vercel.app/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
