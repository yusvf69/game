{
  "version": 2,
  "installCommand": "pnpm install --no-frozen-lockfile --ignore-scripts",
  "buildCommand": "mv tsconfig.json tsconfig.json.ignore && node ./build.mjs",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ]
}
